Import "raylib"

InitWindow(800, 450, "NeoBasic — Raylib Example")
SetTargetFPS(60)

x = 400.0
speed = 200.0

While Not WindowShouldClose()
  dt = GetFrameTime()
  x = x + speed * dt
  If x > 750.0 Or x < 50.0
    speed = speed * -1.0
  EndIf

  pos = New Vector2
  pos.X = x
  pos.Y = 300.0

  BeginDrawing()
  ClearBackground(RAYWHITE())
  DrawText("Hello from NeoBasic!", 190, 200, 20, DARKGRAY())
  DrawCircleV(pos, 50.0, RED())
  EndDrawing()
EndWhile

CloseWindow()
